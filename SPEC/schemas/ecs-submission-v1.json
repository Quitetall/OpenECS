{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lamquant.org/lqs/schemas/ecs-submission-v1.json",
  "title": "EcsSubmission",
  "description": "The OpenECS v1.0 results-submission envelope: the wire format two labs exchange. Mirrors eeg_codec_standard::report::EcsSubmission.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "codec", "corpus", "reports", "summary"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "OpenECS spec version this submission conforms to."
    },
    "codec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Codec report identifier." },
        "manifest_sha256": {
          "type": ["string", "null"],
          "description": "SHA-256 of the codec manifest used, or null for a built-in codec.",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "reports": {
      "type": "array",
      "description": "One EcsReport per graded file.",
      "items": { "$ref": "ecs-report-v1.json" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codec", "n_files", "mean_cr", "mean_prd", "mean_r", "worst_grade", "all_bit_exact"],
      "properties": {
        "codec": { "type": "string" },
        "n_files": { "type": "integer", "minimum": 0 },
        "mean_cr": { "type": "number" },
        "mean_prd": { "type": "number" },
        "mean_r": { "type": "number" },
        "worst_grade": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "description": "Worst (lowest) tier across the corpus; '\\u0000' for below-floor."
        },
        "all_bit_exact": { "type": "boolean" }
      }
    },
    "task_concordance": {
      "description": "Optional, advisory downstream-task-preservation block (OpenECS v1.0 §10). Opaque to the grader; MUST NOT affect any grade. Null/absent when not run.",
      "type": ["object", "null"]
    }
  }
}
